###
### CORE BOT FUNCTIONALITY - required 
###

# MeetingBaas API Key - Used for sending meeting bots as personas to Zoom, Google Meet, Microsoft Teams.
MEETING_BAAS_API_KEY=your_meetingbaas_api_key_here

# OpenAI API Key - Powers the WHOLE bot: speech-to-text, LLM, and text-to-speech
# via the OpenAI Realtime API (speech-to-speech). This is the only AI key needed.
OPENAI_API_KEY=your_openai_api_key_here

#### OpenAI Realtime (speech-to-speech) — replaces Deepgram STT + Cartesia TTS
# Realtime model. Default "gpt-realtime". Your OpenAI account must have access.
OPENAI_REALTIME_MODEL=gpt-realtime
# Fallback Realtime voice if a persona doesn't set `openai_voice` in its README.
# (e.g. sage, marin, cedar, alloy, echo, shimmer). Default "marin".
OPENAI_REALTIME_VOICE=marin
# Cap on tokens per spoken response (dashboard used 2016). Default 2016.
OPENAI_REALTIME_MAX_TOKENS=2016
# Reasoning effort — ONLY applied on reasoning-capable models (gpt-realtime-2).
# Ignored on plain gpt-realtime. One of: minimal, low, medium, high, xhigh.
OPENAI_REALTIME_REASONING_EFFORT=low

# NOTE: Deepgram/Gladia (STT) and Cartesia (TTS) are NO LONGER REQUIRED — the
# Realtime API does all of it. Set them only if you revert scripts/meetingbaas.py
# to the old 3-service pipeline.
# DEEPGRAM_API_KEY=your_deepgram_api_key_here
# CARTESIA_API_KEY=your_cartesia_api_key_here

###
### MULTIPLE BOTS FUNCTIONALITY - can be ignored if only running one bot
###

# Ngrok Auth Token - Used for local development tunneling for multiple bots
NGROK_AUTHTOKEN=your_ngrok_auth_token_here

###
### PERSONAS FUNCTIONALITY - can be ignored if not creating personas
###

# Gemini API Key - Used for persona avatar generation (gemini-2.5-flash-image,
# "nano banana"). Get one free at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# UTFS (UploadThing) - Used to store AI-generated persona avatars.
# Get both at https://uploadthing.com -> create an App -> API Keys tab.
UTFS_KEY=your_utfs_key_here
APP_ID=your_app_id_here

# NOTE: REPLICATE_KEY / STABILITY_AI_API_KEY are no longer used by the avatar
# endpoint (app/services/image_service.py) — it now uses Gemini. They're still
# read by the standalone batch script config/generate_images.py, if you use it.
# REPLICATE_KEY=your_replicate_key_here
# STABILITY_AI_API_KEY=your_stability_ai_key_here

# BASE_URL - Used to determine the WebSocket URL for the bot.
# No trailing slash! (e.g. https://your-app.up.railway.app, not .../ )
BASE_URL=your_base_url_here


